{
	"name": "@socketry/htty",
	"type": "module",
	"version": "0.1.1",
	"description": "HTTY transport, client, and server primitives for JavaScript.",
	"main": "HTTY.js",
	"exports": {
		".": "./HTTY.js",
		"./*": "./HTTY/*.js"
	},
	"files": [
		"HTTY.js",
		"HTTY/"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/socketry/htty-js.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"postinstall": "node scripts/prepare-node-pty.mjs",
		"test": "node --test"
	},
	"keywords": [
		"htty",
		"http2",
		"terminal",
		"socketry"
	],
	"author": "Samuel Williams <samuel.williams@oriontransfer.co.nz> (http://www.codeotaku.com/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/socketry/htty-js/issues"
	},
	"homepage": "https://github.com/socketry/htty-js#readme",
	"devDependencies": {
		"node-pty": "^1.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"node-pty"
		]
	}
}
